# GitHub Copilot token — required for all LLM calls
# Get from: https://github.com/settings/tokens (or your Copilot session token)
GITHUB_TOKEN=your_github_token_here

# Model to use (defaults to gpt-4.1-mini — free on Copilot subscription)
COPILOT_MODEL=gpt-4.1-mini

# Simulation config
SIM_AGENT_COUNT=100
SIM_MIN_WAKE_INTERVAL_SEC=120
SIM_MAX_WAKE_INTERVAL_SEC=900

# API
PORT=3000

# Database path
DB_PATH=./data/slopin.db
